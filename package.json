{
  "name": "pitmaster-tools",
  "private": true,
  "scripts": {
    "build:metros": "node scripts/generate-metros.js",
    "build:guides": "node scripts/generate-guides.js",
    "build": "npm run build:metros && npm run build:guides && node build.js",
    "pins:render": "node scripts/render-pins.mjs",
    "normals:render": "node scripts/generate-normals.mjs",
    "validate": "npm run build && node scripts/validate.mjs",
    "dev:worker": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "npm run test:scripts && vitest run --root worker",
    "test:scripts": "node --test scripts/generate-metros.test.js scripts/generate-guides.test.js scripts/validate-schema.test.js scripts/validate-disclaimers.test.js scripts/build.test.js scripts/validate.test.mjs scripts/plan-url.test.js",
    "test:watch": "vitest --root worker",
    "test:e2e": "playwright test",
    "browser:smoke": "playwright test",
    "typecheck": "tsc -p worker/tsconfig.json --noEmit && tsc -p packages/shared/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.4",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@playwright/test": "^1.54.2",
    "@types/node": "^22.10.5",
    "csso": "^5.0.5",
    "miniflare": "^4.20260508.0",
    "playwright": "^1.54.2",
    "terser": "^5.48.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.53.1",
    "zod": "^4.4.3"
  }
}
