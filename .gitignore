dist/

# Generated passthrough tree: build:metros emits per-metro climate-normals
# distribution JSON here; build.js copies public/ → dist/. Pure build artifact,
# regenerated on every build from the committed data/metro-normals.json.
public/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example
node_modules/
test-results/
.npm-cache/

# Local Claude Code settings (per-developer machine state).
# Team-shareable Claude config — .claude/commands/, .claude/agents/,
# and the project .claude/CLAUDE.md — is intentionally tracked.
.claude/settings.local.json
.claude/logs/
.claude/cache/

# Local scratch / API response cache for offline data scripts (generate-normals.mjs)
.tmp/
